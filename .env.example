# Notion integration — copy this file to .env.local and fill in the values.
# The site renders with built-in sample data when these are not set.

# Internal integration secret from https://www.notion.so/my-integrations
NOTION_TOKEN=

# Database IDs (the 32-char hex in the database URL:
# https://www.notion.so/<workspace>/<DATABASE_ID>?v=...)
NOTION_AWARDEES_DB_ID=
NOTION_BLOG_DB_ID=
NOTION_TOOLS_DB_ID=
